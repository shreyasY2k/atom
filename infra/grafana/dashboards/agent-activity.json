{
  "id": null,
  "uid": "atom-agent-activity",
  "title": "Agent Activity",
  "description": "Per-agent request counts and token consumption",
  "tags": ["atom", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "type": "query",
        "label": "Agent",
        "datasource": { "type": "tempo", "uid": "tempo" },
        "query": "",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "includeAll": true,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests per Agent (rate)",
      "type": "timeseries",
      "description": "LLM call rate per ATOM agent, from atom-llm spans",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-llm\" } | rate() by (span.llm.agent_id)",
          "refId": "A",
          "legendFormat": "{{span.llm.agent_id}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests per Agent (table)",
      "type": "table",
      "description": "Total request count per agent in the selected time range",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-llm\" } | count() by (span.llm.agent_id)",
          "refId": "A",
          "tableType": "spans"
        }
      ]
    },
    {
      "id": 3,
      "title": "GATE Requests by Token Type",
      "type": "piechart",
      "description": "Human vs agent traffic through GATE",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | count() by (span.atom.token_type)",
          "refId": "A",
          "legendFormat": "{{span.atom.token_type}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Recent Agent Spans",
      "type": "traces",
      "description": "Latest LLM calls with agent attribution",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-llm\" }",
          "refId": "A",
          "tableType": "spans",
          "limit": 50
        }
      ]
    }
  ]
}
