{
  "id": null,
  "uid": "atom-gate-overview",
  "title": "GATE Overview",
  "description": "Request rate, latency, and policy decisions for the ATOM GATE service",
  "tags": ["atom", "gate"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (spans/s)",
      "type": "timeseries",
      "description": "Traces per second received from the GATE service",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | rate()",
          "refId": "A",
          "tableType": "spans"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "description": "Request latency p50/p95/p99 (milliseconds)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | quantile_over_time(duration, 0.50)",
          "refId": "P50",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | quantile_over_time(duration, 0.95)",
          "refId": "P95",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | quantile_over_time(duration, 0.99)",
          "refId": "P99",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Policy Denials",
      "type": "timeseries",
      "description": "Requests blocked by OPA policy enforcement",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" && http.status_code=403 } | rate()",
          "refId": "A",
          "legendFormat": "policy denials/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 4,
      "title": "Recent GATE Traces",
      "type": "traces",
      "description": "Latest requests through GATE — click a row to explore the full trace",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 12 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" }",
          "refId": "A",
          "tableType": "spans",
          "limit": 50
        }
      ]
    }
  ]
}
