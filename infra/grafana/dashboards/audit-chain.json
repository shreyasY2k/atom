{
  "id": null,
  "uid": "atom-audit-chain",
  "title": "Audit Chain",
  "description": "ATOM immutable audit chain — entry rate and request coverage across all services",
  "tags": ["atom", "audit", "compliance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Traced Requests (all services)",
      "type": "timeseries",
      "description": "Combined request rate across GATE, atom-llm, and atom-studio",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | rate()",
          "refId": "gate",
          "legendFormat": "gate"
        },
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-llm\" } | rate()",
          "refId": "atom-llm",
          "legendFormat": "atom-llm"
        },
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-studio\" } | rate()",
          "refId": "atom-studio",
          "legendFormat": "atom-studio"
        }
      ]
    },
    {
      "id": 2,
      "title": "GATE Audit Entry Rate",
      "type": "stat",
      "description": "Total GATE request spans (each maps to an audit chain entry)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"gate\" } | count()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Calls Audited",
      "type": "stat",
      "description": "Total atom-llm spans (each is an auditable LLM call event)",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-llm\" } | count()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Studio Operations",
      "type": "stat",
      "description": "Total atom-studio management API spans",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=\"atom-studio\" } | count()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "All Service Traces (audit view)",
      "type": "traces",
      "description": "Full trace history across all ATOM services — export for compliance review",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 14 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"gate|atom-llm|atom-studio\" }",
          "refId": "A",
          "tableType": "spans",
          "limit": 100
        }
      ]
    }
  ]
}
