# ── ATOM agent credentials ────────────────────────────────────────────────────
# Get these from atom-studio after creating a domain and agent:
#   1. Open http://localhost:3000 (docker) or http://studio.atom.local (k8s)
#   2. Domains → New Domain → give it a name
#   3. Agents  → New Agent  → wizard → copy the one-time JWT shown at the end
#   4. Note domain UUID and agent UUID from the Studio URL

ATOM_GATE_URL=http://localhost:8080
ATOM_DOMAIN_ID=<domain-uuid-from-studio-url>
ATOM_AGENT_ID=<agent-uuid-from-studio-url>
ATOM_AGENT_JWT=<one-time-token-shown-after-agent-creation>

# ── Model ─────────────────────────────────────────────────────────────────────
# Must be in the agent's allowed_models list (set during agent creation wizard)
ATOM_MODEL_NAME=gemini-2.5-flash
