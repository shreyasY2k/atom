# Copy to .env and fill in.
# .env is gitignored.

# ----- LiteLLM gateway -----
LITELLM_MASTER_KEY=sk-master-change-me-to-something-random
LITELLM_SALT_KEY=sk-salt-change-me-to-something-else

# ----- Gemini (the only LLM provider for this demo) -----
GEMINI_API_KEY=

# ----- MinIO -----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ----- ReMe (cross-conversation memory) -----
REME_DB_URL=postgresql://reme:reme@reme-db:5432/reme

# ----- Optional: pinned source git refs for build-from-source -----
# Leave commented to use defaults from dockerfiles/*/Dockerfile
# AGENTSCOPE_GIT_REF=v1.2.0
# AGENTSCOPE_RUNTIME_GIT_REF=v1.1.0
# AGENTSCOPE_STUDIO_GIT_REF=main
# REME_GIT_REF=v0.3.1.8
