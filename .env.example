# Copy to .env and fill in.
# .env is gitignored.

# ----- LiteLLM gateway -----
LITELLM_MASTER_KEY=sk-master-change-me-to-something-random
LITELLM_SALT_KEY=sk-salt-change-me-to-something-else

# ----- Gemini (the only LLM provider for this demo) -----
GEMINI_API_KEY=

# ----- MinIO -----
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ----- ReMe (cross-conversation memory) -----
REME_DB_URL=postgresql://reme:reme@reme-db:5432/reme

# ----- Optional: pinned source git refs for build-from-source -----
# Leave commented to use defaults from dockerfiles/*/Dockerfile
# AGENTSCOPE_GIT_REF=v1.2.0
# AGENTSCOPE_RUNTIME_GIT_REF=v1.1.0
# AGENTSCOPE_STUDIO_GIT_REF=main
# REME_GIT_REF=v0.3.1.8

# ----- GitLab CI builds (agent containers) -----
# Set AGENT_BUILD_MODE=gitlab to route agent image builds through GitLab CI
# instead of building locally with docker build.  Leave unset for local builds.
#
# AGENT_BUILD_MODE=gitlab
#
# GITLAB_URL=https://gitlab.com               # or your self-hosted instance URL
# GITLAB_PROJECT_ID=                          # numeric project ID from Settings → General
# GITLAB_ACCESS_TOKEN=                        # token with api + write_repository scopes
# GITLAB_TRIGGER_TOKEN=                       # pipeline trigger token (Settings → CI/CD)
# GITLAB_CI_BRANCH=production                 # branch to commit build context onto + trigger
# GITLAB_BUILD_TIMEOUT=600                    # seconds to wait for the CI pipeline
#
# ATOM_REGISTRY_IMAGE=registry.gitlab.com/your-org/atom  # full image prefix (no trailing slash)
# GITLAB_REGISTRY_USER=                       # deploy token name or "gitlab-ci-token"
# GITLAB_REGISTRY_PASSWORD=                   # deploy token value or project access token
