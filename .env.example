# ATOM — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Postgres ────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is used by k8s-secrets and seed-k8s targets.
# Must match the password set in infra/helm/postgres-values.yaml (auth.password).
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://atom:changeme@localhost:5432/atom?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────────────
# REDIS_PASSWORD is used by k8s-secrets.
# Must match the password set in infra/helm/redis-values.yaml (auth.password).
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379

# ── JWT (GATE uses public key only; studio uses both) ────────────────────────
JWT_PUBLIC_KEY_PATH=/etc/atom/jwt_public.pem
JWT_PRIVATE_KEY_PATH=/etc/atom/jwt_private.pem

# ── Audit chain HMAC (32-byte hex — generate with: openssl rand -hex 32) ────
PLATFORM_HMAC_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── AES encryption key for LiteLLM virtual keys at rest (32-byte hex) ───────
ATOM_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32

# ── OPA ─────────────────────────────────────────────────────────────────────
OPA_BUNDLE_PATH=./policies

# ── Kafka / Redpanda ─────────────────────────────────────────────────────────
KAFKA_BROKERS=redpanda:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_AUDIT=atom-audit

# ── atom-llm ─────────────────────────────────────────────────────────────────
ATOM_LLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-atom-master-changeme

# ── GATE ─────────────────────────────────────────────────────────────────────
GATE_PORT=8080
GATE_ENV=development

# ── atom-studio ──────────────────────────────────────────────────────────────
STUDIO_PORT=3000
STUDIO_ENV=development
ATOM_RUNTIME_URL=http://localhost:8090

# ── OTEL ─────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gate

# ── Platform image registry (docker-compose operator mode) ───────────────────
# Controls which registry docker-compose.yml pulls ATOM service images from.
# Default: ghcr.io/shreyasy2k  (GitHub Container Registry — no login needed)
# GitLab:  registry.gitlab.com/shreyasy2k/atom  (requires: docker login registry.gitlab.com)
ATOM_IMAGE_REGISTRY=ghcr.io/shreyasy2k
# Pin to a specific release (e.g. v1.1.0); leave as 'latest' for rolling updates
ATOM_IMAGE_TAG=latest

# ── GitLab Container Registry (for pulling private agent images) ─────────────
# atom-runtime uses these to pull registry.gitlab.com images in docker mode
# and to create imagePullSecrets in k8s mode (see `make k8s-registry-secret`).
# Scope required: read_registry
GITLAB_REGISTRY_TOKEN=
GITLAB_REGISTRY_USER=oauth2

# k8s only: name of the docker-registry Secret created by `make k8s-registry-secret`
IMAGE_PULL_SECRET_NAME=gitlab-registry-secret

# ── Agent pod vars (injected by atom-runtime — do not set manually) ──────────
# ATOM_AGENT_JWT=
# ATOM_GATE_URL=
# ATOM_AGENT_ID=
# ATOM_DOMAIN_ID=
