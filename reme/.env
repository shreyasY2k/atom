# ReMe runtime environment.
# Loaded by flowllm.core.utils.common_utils.load_env at startup.
# Docker env vars take precedence; these are fallbacks.
OPENAI_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=sk-master-change-me-to-something-random
FLOW_LLM_BASE_URL=http://litellm:4000/v1
FLOW_EMBEDDING_BASE_URL=http://litellm:4000/v1
FLOW_LLM_API_KEY=sk-master-change-me-to-something-random
REME_DB_URL=postgresql://reme:reme@reme-db:5432/reme
REME_VECTOR_STORE=chroma
REME_EMBEDDING_MODEL=gemini-embedding
REME_LLM_MODEL=gemini-3-flash
