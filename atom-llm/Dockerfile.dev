# atom-llm/Dockerfile.dev — ARM64-compatible dev image
#
# Installs LiteLLM from PyPI and layers ATOM extensions on top via
# FastAPI include_router() in main.py.  No source patching.

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install LiteLLM and ATOM runtime dependencies from PyPI.
# Pinned to a specific version so the Prisma schema stays stable across
# rebuilds — an unpinned version can upgrade to a new schema that conflicts
# with the existing postgres_data volume and breaks the prisma db push on startup.
# confluent-kafka may fail on ARM64 wheels — fall back to kafka-python.
RUN pip install --no-cache-dir \
        "litellm[proxy]==1.83.14" \
        "prisma==0.15.0" \
        asyncpg \
        httpx \
        python-dotenv \
        opentelemetry-sdk \
        opentelemetry-exporter-otlp-proto-http \
        confluent-kafka 2>/dev/null \
    || pip install --no-cache-dir \
        "litellm[proxy]==1.83.14" \
        "prisma==0.15.0" \
        asyncpg \
        httpx \
        python-dotenv \
        opentelemetry-sdk \
        opentelemetry-exporter-otlp-proto-http \
        kafka-python

# Generate Prisma client against the installed schema.
RUN SCHEMA=$(python3 -c \
      "import litellm, os; print(os.path.join(os.path.dirname(litellm.__file__), 'proxy', 'schema.prisma'))") && \
    echo "Running prisma generate on ${SCHEMA}" && \
    prisma generate --schema "${SCHEMA}"

# ── ATOM extensions, config, and entry point ─────────────────────────────────
COPY atom_extensions/ /app/atom_extensions/
COPY main.py /app/main.py
# Bake in the dev config so the image works standalone (k8s doesn't need a mount)
COPY config.dev.yaml /app/config.dev.yaml
ENV PYTHONPATH="/app:${PYTHONPATH}"
ENV CONFIG_FILE_PATH="/app/config.dev.yaml"

EXPOSE 4000

CMD ["python", "/app/main.py"]
