# ─── Mode ────────────────────────────────────────────────────
# dev  → call LLM provider directly (no GATE needed)
# prod → route through GATE (requires atom-studio provisioning)
ATOM_MODE=dev

# ─── Dev mode settings ───────────────────────────────────────
# API key for your chosen provider ({{.Provider}})
LLM_API_KEY={{.APIKeyExample}}

# Base URL for the LLM API (OpenAI-compatible)
# OpenAI:          https://api.openai.com/v1
# Anthropic:       https://api.anthropic.com  (via LiteLLM)
# Gemini:          https://generativelanguage.googleapis.com/v1beta/openai
# Local atom-llm:  http://localhost:4000
LLM_BASE_URL={{.ProviderBaseURL}}

# Model to use in dev mode
MODEL_NAME={{.ModelName}}

# ─── Prod mode settings (fill these in after atom-studio provisioning) ─────
# ATOM_GATE_URL=http://localhost:8080
# ATOM_DOMAIN_ID=<your-domain-uuid>
# ATOM_AGENT_ID=<your-agent-uuid>
# ATOM_AGENT_JWT=<one-time-token-from-studio>
# ATOM_MODEL_NAME={{.ModelName}}
