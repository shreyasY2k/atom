# Agent configuration — generated by atom create
# Fill in agent_id and domain_id from atom-studio after creating your agent.
agent_id: ""
domain_id: ""
image: {{ .ProjectName }}
registry: ""  # e.g. registry.gitlab.com/yourorg/{{ .ProjectName }}

ci:
  provider: {{ if .SDKImage }}gitlab{{ else }}local{{ end }}
  origin: gl_origin      # git remote pointing to this repo on GitLab
  branch: main
  registry_secret: GL_REGISTRY_TOKEN

# Pinned atom-sdk base image — run `atom sdk upgrade <tag>` to change version
sdk_image: "{{ if .SDKImage }}{{ .SDKImage }}:latest{{ end }}"
