# sdk_image tag is pinned in atom_agent.yaml — bump it or run: atom sdk upgrade <tag>
ARG SDK_IMAGE={{ if .SDKImage }}{{ .SDKImage }}:latest{{ else }}python:3.11-slim{{ end }}
FROM ${SDK_IMAGE}

WORKDIR /app

# Only agent-specific dependencies here — atom-sdk already in base image when SDK_IMAGE is set
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/healthz')"

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8080"]
