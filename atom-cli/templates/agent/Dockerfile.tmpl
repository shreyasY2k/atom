FROM python:3.11-slim
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Inject GITHUB_TOKEN via BuildKit secret so pip can clone from private repos.
# The token is never stored in any image layer.
# Public repos: build without --secret (required=false skips credential setup).
# Private repos: atom deploy passes --secret id=github_token,env=GITHUB_TOKEN
#   when GITHUB_TOKEN is set in the environment.
RUN --mount=type=secret,id=github_token,required=false \
    TOKEN=$(cat /run/secrets/github_token 2>/dev/null || echo "") && \
    if [ -n "$TOKEN" ]; then \
      git config --global url."https://${TOKEN}@github.com/".insteadOf "https://github.com/"; \
    fi && \
    pip install --no-cache-dir -r requirements.txt && \
    rm -f /root/.gitconfig

COPY . .

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/healthz')"

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8080"]
