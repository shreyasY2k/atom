// Grafana Alloy config — ATOM Agent Platform
// Collects Docker container logs → Loki
// Relays OTEL traces → Tempo (via internal network)

// ── Docker log discovery ───────────────────────────────────────────────────

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"

  filter {
    name   = "status"
    values = ["running"]
  }
}

// Relabel: add container_name + compose_service labels
discovery.relabel "docker_labels" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "service"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "compose_project"
  }
}

// ── Log collection ─────────────────────────────────────────────────────────

loki.source.docker "docker_logs" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_labels.output
  forward_to = [loki.process.parse_json.receiver]

  refresh_interval = "5s"
}

// Try to parse JSON-structured log lines; pass through non-JSON as raw text
loki.process "parse_json" {
  forward_to = [loki.write.local.receiver]

  stage.json {
    expressions = {
      level   = "level",
      event   = "event",
      service = "service",
      run_id  = "run_id",
    }
  }

  stage.labels {
    values = {
      level   = "",
      service = "",
    }
  }
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
  external_labels = {
    platform = "atom-agent-platform",
  }
}

// ── Prometheus metrics scraping (optional — service endpoints) ─────────────

prometheus.scrape "platform_services" {
  targets = [
    {"__address__" = "builder-backend:8080",  "job" = "builder-backend"},
    {"__address__" = "workflow-backend:8081",  "job" = "workflow-backend"},
    {"__address__" = "litellm:4000",           "job" = "litellm"},
  ]
  scrape_interval = "30s"
  metrics_path    = "/metrics"

  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
}

// Write metrics to Grafana's built-in Prometheus (via remote_write to itself)
// In a local stack, point this at prometheus if you have it; for demo we skip
prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = "http://grafana:3001/api/prom/push"
    tls_config {
      insecure_skip_verify = true
    }
  }
}
